	cd /Users/gongzhijie/Desktop/projects/git/galay-rpc/build-docverify && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
